<!-- Add New Period Modal -->
<div id="addPeriodModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50" style="display: none;">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-2xl bg-white">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-medium text-gray-900">Add New Schedule Period</h3>
            <button onclick="closeAddPeriodModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        
        <form id="addPeriodForm" class="space-y-4">
            <!-- Start Date -->
            <div>
                <label for="startDate" class="block text-sm font-medium text-gray-700 mb-2">Start Date</label>
                <input 
                    type="date" 
                    id="startDate" 
                    name="startDate" 
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                    required
                >
            </div>
            
            <!-- End Date -->
            <div>
                <label for="endDate" class="block text-sm font-medium text-gray-700 mb-2">End Date</label>
                <input 
                    type="date" 
                    id="endDate" 
                    name="endDate" 
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                    required
                >
            </div>
            
            <!-- Description -->
            <div>
                <label for="description" class="block text-sm font-medium text-gray-700 mb-2">Description (Optional)</label>
                <input 
                    type="text" 
                    id="description" 
                    name="description" 
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                    placeholder="Enter period description..."
                >
            </div>
            
            <!-- Action Buttons -->
            <div class="flex space-x-3 pt-6">
                <button type="button" onclick="closeAddPeriodModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 border border-transparent rounded-lg font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                    Save
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Shift Assignment Modal -->
<div id="shiftModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50" style="display: none;">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-lg bg-white">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-medium text-gray-900">Shift Assignment</h3>
            <button onclick="closeShiftModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        
        <form class="space-y-4">
            <!-- Shift Type Selection -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-3">Shift Type</label>
                <div class="space-y-2">
                    <label class="flex items-center">
                        <input type="radio" name="shift" value="day" class="w-4 h-4 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500 focus:ring-2" checked>
                        <span class="ml-2 text-sm text-gray-700">Day Shift (8:00 AM - 5:00 PM)</span>
                    </label>
                    <label class="flex items-center">
                        <input type="radio" name="shift" value="night" class="w-4 h-4 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500 focus:ring-2">
                        <span class="ml-2 text-sm text-gray-700">Night Shift (10:00 PM - 7:00 AM)</span>
                    </label>
                    <label class="flex items-center">
                        <input type="radio" name="shift" value="custom" class="w-4 h-4 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500 focus:ring-2">
                        <span class="ml-2 text-sm text-gray-700">Custom Hours</span>
                    </label>
                </div>
            </div>
            
            <!-- Custom Hours (shown when custom is selected) -->
            <div id="customHours" style="display: none;">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Start Time</label>
                        <input type="time" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">End Time</label>
                        <input type="time" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors">
                    </div>
                </div>
            </div>
            
            <!-- Notes Field -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
                <textarea rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors" placeholder="Add any special instructions or notes..."></textarea>
            </div>
            
            <!-- Action Buttons -->
            <div class="flex space-x-3 pt-4">
                <button type="button" onclick="closeShiftModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 border border-transparent rounded-lg font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                    Save Assignment
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function applyFilters() {
    const employee = document.getElementById('employee').value;
    const department = document.getElementById('department').value;
    const week = document.getElementById('week').value;
    
    // This will be implemented when backend is ready
    console.log('Applying schedule filters:', { employee, department, week });
}

// Period Management
function selectPeriod(periodId) {
    // Hide other views
    document.getElementById('weeklyView').style.display = 'none';
    document.getElementById('employeeAssignment').style.display = 'none';
    
    // Show period details view
    document.getElementById('periodDetailsView').style.display = 'block';
    
    // Generate period details based on periodId
    generatePeriodDetails(periodId);
}

function addNewPeriod() {
    document.getElementById('addPeriodModal').style.display = 'block';
}

function closeAddPeriodModal() {
    document.getElementById('addPeriodModal').style.display = 'none';
    // Reset form
    document.getElementById('addPeriodForm').reset();
}

function closeWeeklyView() {
    document.getElementById('weeklyView').style.display = 'none';
}

function closePeriodDetailsView() {
    document.getElementById('periodDetailsView').style.display = 'none';
}

// Generate Period Details
function generatePeriodDetails(periodId) {
    // Sample period data - in real app, this would come from backend
    const periodData = getPeriodData(periodId);
    
    // Update title and subtitle
    document.getElementById('periodDetailsTitle').textContent = periodData.title;
    document.getElementById('periodDetailsSubtitle').textContent = periodData.subtitle;
    
    // Generate week tabs
    generateWeekTabs(periodData.weeks);
    
    // Generate calendar grid for first week
    generateCalendarGrid(periodData.weeks[0]);
}

// Get period data (sample data)
function getPeriodData(periodId) {
    const periods = {
        'period-1': {
            title: 'September 1-15, 2025',
            subtitle: 'Pay Period 1 - Manage schedules for this period',
            weeks: [
                {
                    id: 'week1',
                    name: 'Week 1',
                    dateRange: 'Sep 1-7',
                    startDate: new Date('2025-09-01'),
                    endDate: new Date('2025-09-07'),
                    days: [
                        { date: 'Sep 1', dayOfWeek: 'Mon', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 2', dayOfWeek: 'Tue', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 3', dayOfWeek: 'Wed', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 4', dayOfWeek: 'Thu', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 5', dayOfWeek: 'Fri', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 6', dayOfWeek: 'Sat', isHoliday: false, shifts: [] },
                        { date: 'Sep 7', dayOfWeek: 'Sun', isHoliday: false, shifts: [] }
                    ]
                },
                {
                    id: 'week2',
                    name: 'Week 2',
                    dateRange: 'Sep 8-14',
                    startDate: new Date('2025-09-08'),
                    endDate: new Date('2025-09-14'),
                    days: [
                        { date: 'Sep 8', dayOfWeek: 'Mon', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 9', dayOfWeek: 'Tue', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 10', dayOfWeek: 'Wed', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 11', dayOfWeek: 'Thu', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 12', dayOfWeek: 'Fri', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 13', dayOfWeek: 'Sat', isHoliday: false, shifts: [] },
                        { date: 'Sep 14', dayOfWeek: 'Sun', isHoliday: false, shifts: [] }
                    ]
                },
                {
                    id: 'week3',
                    name: 'Week 3',
                    dateRange: 'Sep 15',
                    startDate: new Date('2025-09-15'),
                    endDate: new Date('2025-09-15'),
                    days: [
                        { date: 'Sep 15', dayOfWeek: 'Mon', isHoliday: true, shifts: [] },
                        { date: '', dayOfWeek: 'Tue', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Wed', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Thu', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Fri', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Sat', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Sun', isHoliday: false, shifts: [] }
                    ]
                }
            ]
        },
        'period-2': {
            title: 'September 16-30, 2025',
            subtitle: 'Pay Period 2 - Manage schedules for this period',
            weeks: [
                {
                    id: 'week1',
                    name: 'Week 1',
                    dateRange: 'Sep 16-22',
                    startDate: new Date('2025-09-16'),
                    endDate: new Date('2025-09-22'),
                    days: [
                        { date: 'Sep 16', dayOfWeek: 'Mon', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 17', dayOfWeek: 'Tue', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 18', dayOfWeek: 'Wed', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 19', dayOfWeek: 'Thu', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 20', dayOfWeek: 'Fri', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 21', dayOfWeek: 'Sat', isHoliday: false, shifts: [] },
                        { date: 'Sep 22', dayOfWeek: 'Sun', isHoliday: false, shifts: [] }
                    ]
                },
                {
                    id: 'week2',
                    name: 'Week 2',
                    dateRange: 'Sep 23-29',
                    startDate: new Date('2025-09-23'),
                    endDate: new Date('2025-09-29'),
                    days: [
                        { date: 'Sep 23', dayOfWeek: 'Mon', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 24', dayOfWeek: 'Tue', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 25', dayOfWeek: 'Wed', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 26', dayOfWeek: 'Thu', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 27', dayOfWeek: 'Fri', isHoliday: false, shifts: ['day'] },
                        { date: 'Sep 28', dayOfWeek: 'Sat', isHoliday: false, shifts: [] },
                        { date: 'Sep 29', dayOfWeek: 'Sun', isHoliday: false, shifts: [] }
                    ]
                },
                {
                    id: 'week3',
                    name: 'Week 3',
                    dateRange: 'Sep 30',
                    startDate: new Date('2025-09-30'),
                    endDate: new Date('2025-09-30'),
                    days: [
                        { date: 'Sep 30', dayOfWeek: 'Mon', isHoliday: false, shifts: ['day'] },
                        { date: '', dayOfWeek: 'Tue', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Wed', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Thu', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Fri', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Sat', isHoliday: false, shifts: [] },
                        { date: '', dayOfWeek: 'Sun', isHoliday: false, shifts: [] }
                    ]
                }
            ]
        }
    };
    
    return periods[periodId] || periods['period-1'];
}

// Generate Week Tabs
function generateWeekTabs(weeks) {
    const container = document.getElementById('weekTabsContainer');
    container.innerHTML = '';
    
    weeks.forEach((week, index) => {
        const tab = document.createElement('button');
        tab.className = `week-tab flex-1 px-4 py-2 text-sm font-medium rounded-md transition-colors ${index === 0 ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-600 hover:text-gray-900'}`;
        tab.textContent = `${week.name} (${week.dateRange})`;
        tab.onclick = () => selectPeriodWeek(week.id, week);
        
        container.appendChild(tab);
    });
}

// Generate Calendar Grid
function generateCalendarGrid(week) {
    const container = document.getElementById('calendarGridContainer');
    
    // Day headers
    const dayHeaders = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
    
    container.innerHTML = `
        <div class="grid grid-cols-7 gap-2 mb-4">
            ${dayHeaders.map(day => `<div class="text-center text-sm font-medium text-gray-500 py-2">${day}</div>`).join('')}
        </div>
        <div class="grid grid-cols-7 gap-2">
            ${week.days.map(day => generateDayCell(day)).join('')}
        </div>
    `;
}

// Generate Day Cell
function generateDayCell(day) {
    if (!day.date) {
        return '<div class="border border-gray-200 rounded-lg p-3 min-h-24 bg-gray-50"></div>';
    }
    
    const holidayBadge = day.isHoliday ? 
        '<div class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800 mb-2"><i class="fas fa-calendar-times mr-1"></i>Holiday</div>' : '';
    
    const shiftToggles = generateShiftToggles(day.shifts, day.date);
    
    const employeeDropdown = generateEmployeeDropdown(day.date);
    
    return `
        <div class="border border-gray-200 rounded-lg p-3 min-h-32 hover:shadow-md transition-shadow">
            <div class="text-sm font-medium text-gray-900 mb-2">${day.date}</div>
            ${holidayBadge}
            <div class="space-y-2">
                ${shiftToggles}
                ${employeeDropdown}
            </div>
        </div>
    `;
}

// Generate Shift Toggles
function generateShiftToggles(shifts, date) {
    const shiftTypes = [
        { id: 'day', label: '☀️ Day', icon: 'fas fa-sun', color: 'bg-yellow-100 text-yellow-800' },
        { id: 'night', label: '🌙 Night', icon: 'fas fa-moon', color: 'bg-blue-100 text-blue-800' },
        { id: 'custom', label: '⚙️ Custom', icon: 'fas fa-cog', color: 'bg-purple-100 text-purple-800' }
    ];
    
    return `
        <div class="space-y-1">
            ${shiftTypes.map(shift => `
                <label class="flex items-center cursor-pointer">
                    <input 
                        type="checkbox" 
                        class="w-4 h-4 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500 focus:ring-2 mr-2"
                        ${shifts.includes(shift.id) ? 'checked' : ''}
                        onchange="toggleShift('${date}', '${shift.id}', this.checked)"
                    >
                    <span class="text-xs font-medium ${shift.color} px-2 py-1 rounded-full">${shift.label}</span>
                </label>
            `).join('')}
        </div>
    `;
}

// Generate Employee Dropdown
function generateEmployeeDropdown(date) {
    return `
        <div class="mt-2">
            <select class="w-full text-xs border border-gray-300 rounded px-2 py-1 focus:ring-1 focus:ring-blue-500 focus:border-transparent" onchange="assignEmployeeToDay('${date}', this.value)">
                <option value="">Select Employee</option>
                <option value="john-smith">John Smith</option>
                <option value="sarah-johnson">Sarah Johnson</option>
                <option value="michael-brown">Michael Brown</option>
            </select>
        </div>
    `;
}

// Select Period Week
function selectPeriodWeek(weekId, week) {
    // Update tab styles
    document.querySelectorAll('.week-tab').forEach(tab => {
        tab.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
        tab.classList.add('text-gray-600');
    });
    
    event.target.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
    event.target.classList.remove('text-gray-600');
    
    // Generate calendar grid for selected week
    generateCalendarGrid(week);
}

